# Local-Lite Example Configuration
# Designed for running without Docker/Redis/K8s overhead

DEPLOYMENT_PROFILE=local-lite
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database is still required natively or via an external lightweight service
DATABASE_URL=postgres://aapsd_user:aapsd_pass@localhost:5432/aapsd_db

# Redis is NOT required in local-lite
REDIS_URL=

# External integrations (Mocked in local-lite)
OPENROUTER_API_KEY=dummy_key_replace_me
GITHUB_TOKEN=dummy
K8S_TOKEN=dummy

# Mutable Actions are disabled natively in local-lite regardless of these settings
ACTION_MIN_SCALE=1
ACTION_MAX_SCALE=1
