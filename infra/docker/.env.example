# Example Environment Variables for AAPSD-Assistant
# NEVER place real secrets in this file. Copy to .env and fill in values.

# Server Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database & Cache
DATABASE_URL=postgres://aapsd_user:aapsd_pass@db:5432/aapsd_db
REDIS_URL=redis://redis:6379

# Model Provider
OPENROUTER_API_KEY=dummy_key_replace_me

# GitHub Integration
GITHUB_TOKEN=dummy_github_token_replace_me
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
GITHUB_ALLOWED_REPOS=owner/repo-name
GITHUB_ALLOWED_WORKFLOWS=deploy.yml,test.yml

# Kubernetes Integration
K8S_TOKEN=dummy_k8s_token_replace_me
K8S_API_SERVER_URL=https://dummy-k8s-api
K8S_ALLOWED_NAMESPACES=default,staging

# Prometheus Integration
PROMETHEUS_BASE_URL=http://dummy-prometheus
PROMETHEUS_ALLOWED_METRICS=cpu,memory,requests

# Execution Policies
ACTION_ALLOWED_DEPLOYMENTS=api-deployment,web-deployment
ACTION_MIN_SCALE=1
ACTION_MAX_SCALE=5

# Webhook Security
WEBHOOK_SECRET=dummy_webhook_secret_replace_me
