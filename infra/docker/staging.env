# Staging Environment Configuration
# This configuration is meant to run a local staging environment that closely mirrors production.
# Mutable actions are DISABLED by default for safety during demonstrations.

PORT=3000
NODE_ENV=production
CORS_ORIGIN=http://localhost:5173

DATABASE_URL=postgres://aapsd_user:aapsd_pass@db:5432/aapsd_db
REDIS_URL=redis://redis:6379

# Safely disabled mutable actions
GITHUB_ALLOWED_REPOS=
GITHUB_ALLOWED_WORKFLOWS=
K8S_ALLOWED_NAMESPACES=
ACTION_ALLOWED_DEPLOYMENTS=
ACTION_MIN_SCALE=1
ACTION_MAX_SCALE=1

# External integrations (provide your own dummy/staging keys when testing)
OPENROUTER_API_KEY=dummy_key_replace_me
GITHUB_TOKEN=dummy_github_token_replace_me
K8S_TOKEN=dummy_k8s_token_replace_me
K8S_API_SERVER_URL=https://dummy-k8s-api
PROMETHEUS_BASE_URL=http://dummy-prometheus
WEBHOOK_SECRET=dummy_webhook_secret_replace_me
