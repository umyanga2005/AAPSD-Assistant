{
  "name": "@aapsd/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "start": "node --env-file=.env dist/index.js",
    "dev": "node --watch --env-file=.env --import tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env --import tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aapsd/contracts": "*",
    "@aapsd/diagnosis": "*",
    "@fastify/cors": "^11.3.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/websocket": "^11.3.0",
    "@sinclair/typebox": "^0.34.52",
    "bullmq": "^5.80.3",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.0.0",
    "firebase-admin": "^14.1.0",
    "ioredis": "^5.11.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.16.0",
    "vitest": "^2.0.0"
  }
}
